    <string name="privacy_policy_title">Privacy policy</string>
    <string name="privacy_disclosure_title">Before enabling forwarding</string>
    <string name="privacy_disclosure_body">NotifyBridge can read notifications you allow through Android notification access, inspect installed app names for filtering, and forward selected notification content to the delivery channel you configure. Depending on your settings, forwarded data can include app name, package name, title, body text, subtext, device model, Android version, and channel-specific routing data.</string>
    <string name="privacy_disclosure_points_title">What you are agreeing to</string>
    <string name="privacy_disclosure_point_notifications">Read real-time notifications after you grant Notification access.</string>
    <string name="privacy_disclosure_point_apps">Read installed app names and package names so you can choose which apps to forward or block.</string>
    <string name="privacy_disclosure_point_transfer">Send selected notification content to Bark, Telegram, Slack, or Email based on your settings.</string>
    <string name="privacy_disclosure_point_control">You can disable forwarding, revoke notification access, or clear local logs at any time.</string>
    <string name="privacy_disclosure_agree">I understand and agree</string>
    <string name="privacy_disclosure_policy">Read privacy policy</string>
    <string name="privacy_policy_summary">NotifyBridge processes notification content on-device and forwards only the data required by your configured channel.</string>
    <string name="privacy_policy_section_data_title">Data we process</string>
    <string name="privacy_policy_section_data_body">We may process notification metadata and content such as app name, package name, title, text, subtext, posted time, and device information. If you use app-based filters, the app also reads installed app names and package names on your device.</string>
    <string name="privacy_policy_section_usage_title">How data is used</string>
    <string name="privacy_policy_section_usage_body">Data is used to filter notifications, show delivery logs on your device, and forward selected notifications to the delivery destination you configure.</string>
    <string name="privacy_policy_section_sharing_title">Third-party sharing</string>
    <string name="privacy_policy_section_sharing_body">When forwarding is enabled, NotifyBridge sends selected notification data to the third-party service you choose, such as Bark, Telegram, Slack, or your email provider. Their handling of data is governed by their own policies.</string>
    <string name="privacy_policy_section_storage_title">Local storage</string>
    <string name="privacy_policy_section_storage_body">Settings, delivery history, and failed queue records are stored locally on the device. Secrets such as tokens or SMTP credentials are currently stored locally for delivery automation.</string>
    <string name="privacy_policy_section_controls_title">User controls</string>
    <string name="privacy_policy_section_controls_body">You can turn forwarding off, remove channel credentials, revoke notification access in Android settings, or clear exported logs and local history from the app.</string>
    <string name="privacy_policy_section_contact_title">Publisher note</string>
    <string name="privacy_policy_section_contact_body">Before publishing to Google Play, replace this in-app policy summary with your public privacy policy URL, publisher contact details, and any service-specific retention details.</string>

